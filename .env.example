# One-shot autonomous mode
# When set, /start-project skips the Phase 5 review stop
# and proceeds directly into Phase 6 execution.
AUTOPILOT=true

# Auto-deploy after Phase 10 validation
# When set, the orchestrator delegates deployment to the devops agent
# after passing the Phase 10 goal validation checklist.
# Deployment failure does not block the production-ready verdict.
AUTODEPLOY=true
