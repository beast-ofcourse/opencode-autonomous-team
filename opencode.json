{
  "$schema": "https://opencode.ai/config.json",

  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",

  "default_agent": "orchestrator",

  "autoupdate": true,

  "snapshot": true,

  "share": "manual",

  "formatter": true,

  "lsp": true,

  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "coverage/**",
      ".next/**",
      "__pycache__/**",
      "*.pyc"
    ]
  },

  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow",
    "websearch": "allow"
  },

  "instructions": [
    "AGENTS.md"
  ],

  "mcp": {
    "github": {
      "command": "npx",
      "args": ["-y", "@openctx/provider-github"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "context7-mcp-server"]
    }
  },

  "agent": {
    "researcher": {
      "model": "small_model"
    },
    "docs-writer": {
      "model": "small_model"
    },
    "planner": {
      "model": "small_model"
    },
    "perfectionist": {
      "steps": 120
    },
    "swe-debugger": {
      "steps": 150
    },
    "swe-testing": {
      "steps": 150
    },
    "swe-refactor": {
      "steps": 150
    },
    "devops": {
      "steps": 150
    },
    "swe-security": {
      "steps": 150
    }
  }
}
