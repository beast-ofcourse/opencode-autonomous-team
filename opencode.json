{
  "$schema": "https://opencode.ai/config.json",

  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",

  "default_agent": "orchestrator",

  "autoupdate": true,

  "snapshot": true,

  "share": "manual",

  "formatter": true,

  "lsp": true,

  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "coverage/**",
      ".next/**",
      "__pycache__/**",
      "*.pyc"
    ]
  },

  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow",
    "websearch": "allow"
  },

  "instructions": [
    "AGENTS.md"
  ],

  "mcp": {
  },

  "agent": {
  }
}
